{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash",
      "WebSearch",
      "WebFetch"
    ],
    "deny": [],
    "ask": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/workflow_gate.py\" ]; then python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/workflow_gate.py\"; fi",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/spec_enforcement.py\" ]; then python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/spec_enforcement.py\"; fi",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/claude_md_protection.py\" ]; then python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/claude_md_protection.py\"; fi",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/tdd_enforcement.py\" ]; then python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/tdd_enforcement.py\"; fi",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/red_test_gate.py\" ]; then python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/red_test_gate.py\"; fi",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/post_implementation_gate.py\" ]; then python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/post_implementation_gate.py\"; fi",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/scope_guard.py\" ]; then python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/scope_guard.py\"; fi",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/plan_validator.py\" ]; then python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/plan_validator.py\"; fi",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/ui_screenshot_gate.py\" ]; then python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/ui_screenshot_gate.py\"; fi",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/domain_pattern_guard.py\" ]; then python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/domain_pattern_guard.py\"; fi",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/architecture_guard.py\" ]; then python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/architecture_guard.py\"; fi",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/track_changes.py\" ]; then python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/track_changes.py\"; fi",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/backlog_guard.py\" ]; then python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/backlog_guard.py\"; fi",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/data_schema_backup.py\" ]; then python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/data_schema_backup.py\"; fi",
            "timeout": 35
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/pre_commit_gate.py\" ]; then python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/pre_commit_gate.py\"; fi",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/pre_commit_validation.py\" ]; then python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/pre_commit_validation.py\"; fi",
            "timeout": 180
          },
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/secrets_guard.py\" ]; then python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/secrets_guard.py\"; fi",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/e2e_commit_gate.py\" ]; then python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/e2e_commit_gate.py\"; fi",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/pre_issue_close_design_gate.py\" ]; then python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/pre_issue_close_design_gate.py\"; fi",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/secrets_guard.py\" ]; then python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/secrets_guard.py\"; fi",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/session_singleton_guard.py\" ]; then python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/session_singleton_guard.py\" guard; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/hem/claude-mq/check-messages.sh"
          },
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/session_singleton_guard.py\" ]; then python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/session_singleton_guard.py\" register; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/notify_sound.py\" ]; then python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/notify_sound.py\"; fi",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/workflow_state_updater.py\" ]; then python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/workflow_state_updater.py\"; fi",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/auto_restart_server.py\" ]; then python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/auto_restart_server.py\"; fi",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f \"${CLAUDE_PROJECT_DIR}/.claude/hooks/edit_verify.py\" ]; then python3 \"${CLAUDE_PROJECT_DIR}/.claude/hooks/edit_verify.py\"; fi",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
